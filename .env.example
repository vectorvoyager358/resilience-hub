# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key_here
# Frontend embeddings (challenge notes synced to Pinecone / chat context)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Cloud Run / local Flask — full origin, no trailing slash (omit for local dev + Vite proxy)
# VITE_API_BASE_URL=https://your-api-xxxxx.run.app

# GitHub Pages / subpath hosting — leading slash + repo folder + trailing slash (omit for local dev)
# VITE_BASE_PATH=/resilience-hub/

# Add any other environment variables your app needs below 