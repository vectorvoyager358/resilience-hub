    "@mui/icons-material": "^5.17.1",
    "@mui/material": "^5.15.10",
    "@mui/x-date-pickers": "^6.19.7",
    "@types/jspdf": "^1.3.3",
    "chart.js": "^4.4.9",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "firebase": "^11.6.1",
    "framer-motion": "^12.9.1",
    "fuse.js": "^7.1.0",
